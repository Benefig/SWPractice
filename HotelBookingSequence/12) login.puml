@startuml Login User (POST)

header Hotel Booking Sequence Diagram
footer Page 12 of 13
title "Login User (POST)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase

client -> server ++ : req.post('/api/v1/auth/login')
server -> routerAuth ++
routerAuth -> controllersAuth ++ : login()

controllersAuth -> modelUser ++ : findOne({email}).select('+password')
modelUser -> UsersDatabase ++ : Query user
UsersDatabase --> modelUser -- : user
modelUser --> controllersAuth -- : user

controllersAuth -> modelUser ++ : matchPassword(password)
modelUser --> controllersAuth -- : isMatch

controllersAuth -> modelUser ++ : getSignedJwtToken()
modelUser --> controllersAuth -- : token

controllersAuth -> client -- : response: Set-Cookie(token) + JSON {success, token}

@enduml