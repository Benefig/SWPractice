@startuml Get Current User (GET)

header Hotel Booking Sequence Diagram
footer Page 13 of 13
title "Get Current Logged In User (GET)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<middleware>>\n:protect" as middlewareProtect
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase

client -> server ++ : req.get('/api/v1/auth/me')
server -> routerAuth ++
routerAuth -> middlewareProtect ++ : protect()
middlewareProtect -> controllersAuth ++ : getMe()

controllersAuth -> modelUser ++ : findById(req.user.id)
modelUser -> UsersDatabase ++ : Query user
UsersDatabase --> modelUser -- : user
modelUser --> controllersAuth -- : user

controllersAuth -> client -- : response: JSON {success, data: user}

@enduml